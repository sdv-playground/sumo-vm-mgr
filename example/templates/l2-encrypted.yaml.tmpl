component_id: "${COMPONENT}"
sequence_number: ${SEQ}
security_version: ${SECVER}
signing_key: ${KEYS_DIR}/signing.key

payload:
  file: ${FW_PATH}
  uri: "#firmware"
  compress: true
  encrypt:
    device_keys: ["${KEYS_DIR}/device.pub"]

output:
  manifest: ${MANIFEST_PATH}

metadata:
  version: "${VERSION}"
  vendor_name: "vm-mgr"
  model_name: "${MODEL_NAME}"
  model_info: "${MODEL_INFO}"
  description: "${DESCRIPTION}"
